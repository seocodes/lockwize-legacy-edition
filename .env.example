# Frontend
REACT_APP_API_URL=http://localhost:8080

# Backend
APP_PUBLIC_URL=http://localhost:3000
APP_EMAIL_FROM=Lockwize <no-reply@example.com>
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
SPRING_DATASOURCE_URL=jdbc:h2:mem:lockwize;DB_CLOSE_DELAY=-1;MODE=PostgreSQL;DATABASE_TO_LOWER=TRUE;DEFAULT_NULL_ORDERING=HIGH
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
JWT_SECRET=replace-with-a-long-random-secret-before-deploy
JWT_EXPIRATION=86400000

# Optional legacy email integrations
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
RESEND_API_KEY=
